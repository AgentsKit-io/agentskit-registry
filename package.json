{
  "name": "agentskit-registry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Ready-to-use AI agents for AgentsKit — copy the source into your project (shadcn-style).",
  "homepage": "https://registry.agentskit.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-registry.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build-registry.mjs",
    "catalog:generate": "node scripts/generate-catalog.mjs",
    "catalog:validate": "node scripts/validate-catalog.mjs",
    "scaffold": "node scripts/scaffold-draft.mjs",
    "validate": "node scripts/validate-agents.mjs && node scripts/validate-catalog.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@agentskit/adapters": "^0.12.2",
    "@agentskit/core": "^1.10.0",
    "@agentskit/eval": "^0.4.5",
    "@agentskit/runtime": "^0.10.0",
    "@agentskit/skills": "^0.8.2",
    "@agentskit/tools": "^0.9.4",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.19.20",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.0"
  }
}
