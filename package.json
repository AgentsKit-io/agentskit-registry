{
  "name": "agentskit-registry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Ready-to-use AI agents for AgentsKit — copy the source into your project (shadcn-style).",
  "homepage": "https://registry.agentskit.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-registry.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview",
    "build:registry": "node scripts/build-registry.mjs",
    "build": "npm run build:registry && astro build",
    "validate": "node scripts/validate-agents.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.agents.json",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/vercel": "^8.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^5.14.1",
    "marked": "^14.1.4",
    "shiki": "^1.29.2",
    "satori": "^0.12.2"
  },
  "devDependencies": {
    "@agentskit/adapters": "^0.12.2",
    "@agentskit/core": "^1.9.0",
    "@agentskit/eval": "^0.4.5",
    "@agentskit/runtime": "^0.7.3",
    "@agentskit/skills": "^0.8.2",
    "@agentskit/tools": "^0.9.4",
    "@astrojs/check": "^0.9.9",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.19.20",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.0"
  }
}
