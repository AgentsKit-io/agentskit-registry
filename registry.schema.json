{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://registry.agentskit.io/registry.schema.json",
  "title": "AgentsKit Registry — agent meta",
  "type": "object",
  "required": ["id", "title", "description", "category", "packages", "files"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "source": { "type": "string" },
    "license": { "type": "string" },
    "requires": { "type": "object" },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "deprecated"],
      "description": "draft = catalog only, not installable; validated = npx agentskit add; deprecated = sunset."
    },
    "category": {
      "type": "string",
      "enum": [
        "research", "coding", "data", "support", "ops", "content", "productivity",
        "clinical", "fintech", "legal", "marketing", "agency",
        "sales", "hr", "devops", "ecommerce", "product", "cybersecurity",
        "insurance", "realestate", "education", "compliance", "ecosystem"
      ]
    },
    "locale": {
      "type": "string",
      "description": "Optional locale hint (e.g. br, eu) for jurisdiction-specific agents."
    },
    "ecosystem": {
      "type": "boolean",
      "description": "True when the agent dogfoods the AgentsKit ecosystem (doc-bridge, playbook, registry)."
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "packages": {
      "description": "Published @agentskit/* packages the copied agent depends on.",
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "env": {
      "description": "Environment variables the agent needs at runtime.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "files": {
      "description": "Files copied into the consumer project, relative to the agent folder.",
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
  }
}
