---
import Icon from './Icon.astro'
import { getLocale, t } from '../i18n/ui'

const locale = getLocale(Astro.currentLocale)
const tr = t(locale)

// Brand logos via the same source AgentsKit uses: cdn.simpleicons.org/<slug>.
// Near-black brands get a light tint so they stay visible on the dark surface.
type Brand = { name: string; slug: string; dark?: boolean }
const TINT = '8b949e'
const integrations: Brand[] = [
  { name: 'Slack', slug: 'slack' },
  { name: 'Notion', slug: 'notion', dark: true },
  { name: 'Stripe', slug: 'stripe' },
  { name: 'GitHub', slug: 'github', dark: true },
  { name: 'Gmail', slug: 'gmail' },
  { name: 'Google Calendar', slug: 'googlecalendar' },
  { name: 'Google Drive', slug: 'googledrive' },
  { name: 'Jira', slug: 'jira' },
  { name: 'Linear', slug: 'linear' },
  { name: 'HubSpot', slug: 'hubspot' },
  { name: 'Intercom', slug: 'intercom' },
  { name: 'Discord', slug: 'discord' },
  { name: 'Telegram', slug: 'telegram' },
  { name: 'WhatsApp', slug: 'whatsapp' },
  { name: 'Shopify', slug: 'shopify' },
  { name: 'Airtable', slug: 'airtable' },
  { name: 'Asana', slug: 'asana' },
  { name: 'Confluence', slug: 'confluence' },
  { name: 'Dropbox', slug: 'dropbox' },
  { name: 'Figma', slug: 'figma' },
  { name: 'Sentry', slug: 'sentry', dark: true },
  { name: 'Mailchimp', slug: 'mailchimp' },
  { name: 'ElevenLabs', slug: 'elevenlabs', dark: true },
  { name: 'Cal.com', slug: 'caldotcom', dark: true },
  { name: 'Calendly', slug: 'calendly' },
  { name: 'Google Maps', slug: 'googlemaps' },
]
const providers: Brand[] = [
  { name: 'OpenAI', slug: 'openai', dark: true },
  { name: 'Anthropic', slug: 'anthropic', dark: true },
  { name: 'Google', slug: 'google' },
  { name: 'Vertex AI', slug: 'googlecloud' },
  { name: 'xAI', slug: 'x', dark: true },
  { name: 'Mistral', slug: 'mistralai' },
  { name: 'DeepSeek', slug: 'deepseek' },
  { name: 'Alibaba', slug: 'alibabacloud' },
  { name: 'Cloudflare', slug: 'cloudflare' },
  { name: 'Hugging Face', slug: 'huggingface' },
  { name: 'OpenRouter', slug: 'openrouter', dark: true },
  { name: 'Perplexity', slug: 'perplexity' },
  { name: 'Vercel', slug: 'vercel', dark: true },
]
const logo = (b: Brand) => `https://cdn.simpleicons.org/${b.slug}${b.dark ? '/' + TINT : ''}`

const intUrl = 'https://www.agentskit.io/docs/agents/tools/integrations'
const provUrl = 'https://www.agentskit.io/docs/data/providers'
const intRow = [...integrations, ...integrations]
const provRow = [...providers, ...providers]
---
<section class="section works">
  <div class="container">
    <span class="eyebrow reveal">{tr.works.eyebrow}</span>
    <h2 class="section-title reveal">{tr.works.title}</h2>
    <p class="section-sub reveal">{tr.works.sub}</p>
    <div class="works-links reveal">
      <a href={intUrl} rel="noopener">{tr.works.integrations}<Icon name="arrow-right" size={15} /></a>
      <a href={provUrl} rel="noopener">{tr.works.providers}<Icon name="arrow-right" size={15} /></a>
    </div>

    <div class="marquee reveal" aria-hidden="true">
    <div class="mq-row">
      <div class="mq-track">
        {
          intRow.map((b) => (
            <span class="chip">
              <img class="chip-logo" src={logo(b)} alt="" width="18" height="18" loading="lazy" onerror="this.remove()" />
              {b.name}
            </span>
          ))
        }
      </div>
    </div>
    <div class="mq-row">
      <div class="mq-track mq-rev">
        {
          provRow.map((b) => (
            <span class="chip">
              <img class="chip-logo" src={logo(b)} alt="" width="18" height="18" loading="lazy" onerror="this.remove()" />
              {b.name}
            </span>
          ))
        }
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  .works {
    position: relative;
    overflow: hidden;
  }
  .works-links {
    display: flex;
    gap: 22px;
    margin-top: 20px;
    flex-wrap: wrap;
  }
  .works-links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .works-links a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .marquee {
    margin-top: 34px;
    display: grid;
    gap: 14px;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .mq-row {
    overflow: hidden;
  }
  .mq-track {
    display: flex;
    gap: 12px;
    width: max-content;
    animation: marq 60s linear infinite;
  }
  .mq-rev {
    animation-direction: reverse;
    animation-duration: 48s;
  }
  .marquee:hover .mq-track {
    animation-play-state: paused;
  }
  @keyframes marq {
    to {
      transform: translateX(-50%);
    }
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    flex: none;
    padding: 9px 16px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }
  .chip-logo {
    width: 18px;
    height: 18px;
    object-fit: contain;
    flex: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .mq-track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
    }
    .marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
