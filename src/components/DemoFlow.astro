---
import Icon from './Icon.astro'
import { getLocale, t, categoryMeta } from '../i18n/ui'
import type { AgentSummary } from '../data/registry'

interface Props {
  agents: AgentSummary[]
  agentCount: number
  categoryCount: number
}
const { agents, agentCount, categoryCount } = Astro.props
const locale = getLocale(Astro.currentLocale)
const tr = t(locale)

// Five visible slots; connector paths are drawn in pixels by JS so they always
// touch the core card and each row (layout() recomputes on load + resize).
const ROWS = 5
const payload = agents.map((a) => ({
  id: a.id,
  title: a.title,
  category: a.category,
  cat: categoryMeta(locale, a.category).label,
  runnable: a.runnable,
}))
const first = payload.slice(0, ROWS)
---
<section class="section demo">
  <div class="container">
    <span class="eyebrow reveal">{tr.demo.eyebrow}</span>
    <h2 class="section-title reveal">{tr.demo.title}</h2>
    <p class="section-sub reveal">{tr.demo.sub}</p>

    <div class="demo-stage reveal" data-agents={JSON.stringify(payload)}>
      <!-- connectors (paths set by JS in layout()) -->
      <svg class="demo-svg" preserveAspectRatio="none" aria-hidden="true">
        {Array.from({ length: ROWS }).map((_, i) => <path class="demo-line" data-line={i} />)}
      </svg>

      <!-- left: registry core -->
      <div class="demo-core">
        <div class="core-top">
          <span class="core-mark"><Icon name="box" size={16} /></span>
          <span class="core-label">{tr.demo.coreLabel}</span>
        </div>
        <div class="core-num">{agentCount}</div>
        <div class="core-sub">{agentCount} {tr.stats.agents} · {categoryCount} {tr.stats.categories} · MIT</div>
        <div class="core-cmd">
          <code><span class="cc-prompt">$</span> npx agentskit add <span id="demo-id">{first[0]?.id}</span></code>
          <button
            id="demo-copy"
            class="cc-copy"
            type="button"
            data-copy={`npx agentskit add ${first[0]?.id}`}
            data-label="copy"
            data-copied="ok"
            aria-label={tr.hero.copyHint}
          >
            <Icon name="copy" size={14} class="cc-c" />
            <Icon name="check" size={14} class="cc-k" />
          </button>
        </div>
        <p class="core-tag">{tr.demo.coreSub}</p>
      </div>

      <!-- right: cycling agents -->
      <ul class="demo-rows">
        {
          first.map((a, i) => (
            <li class="demo-row" data-row={i}>
              <span class="row-dot" />
              <span class="row-name">{a.title}</span>
              <span class="row-cat">{a.cat}</span>
              {a.runnable && <span class="row-run">●</span>}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .demo-stage {
    position: relative;
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 0;
    align-items: center;
    margin-top: 34px;
    min-height: 320px;
  }
  .demo-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .demo-line {
    fill: none;
    stroke: color-mix(in srgb, var(--accent) 35%, var(--border));
    stroke-width: 1.5;
    stroke-dasharray: 4 6;
    animation: flow 1.6s linear infinite;
  }
  .demo-line.active {
    stroke: var(--accent);
    stroke-width: 2.2;
    filter: drop-shadow(0 0 5px var(--accent-soft));
  }
  @keyframes flow {
    to {
      stroke-dashoffset: -16;
    }
  }
  .demo-core {
    position: relative;
    z-index: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px;
    box-shadow: var(--shadow);
  }
  .core-top {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
  }
  .core-mark {
    display: inline-flex;
    color: var(--accent);
  }
  .core-label {
    font-family: var(--mono);
    font-size: 0.9rem;
  }
  .core-num {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1;
    margin: 12px 0 4px;
    letter-spacing: -0.03em;
  }
  .core-sub {
    color: var(--faint);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .core-cmd {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 18px;
    background: var(--bg);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-sm);
    padding: 9px 9px 9px 13px;
    font-family: var(--mono);
    font-size: 0.78rem;
  }
  .core-cmd code {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text);
  }
  .cc-prompt {
    color: var(--accent);
  }
  #demo-id {
    color: var(--accent-2);
    transition: color 0.2s ease;
  }
  .cc-copy {
    position: relative;
    width: 28px;
    height: 28px;
    flex: none;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .cc-copy:hover {
    color: var(--text);
    border-color: var(--accent);
  }
  .cc-copy :global(svg) {
    position: absolute;
    transition: opacity 0.15s ease;
  }
  .cc-k {
    opacity: 0;
    color: var(--green);
  }
  .cc-copy.is-copied .cc-c {
    opacity: 0;
  }
  .cc-copy.is-copied .cc-k {
    opacity: 1;
  }
  .core-tag {
    margin: 14px 0 0;
    color: var(--faint);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .demo-rows {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: 0;
    padding: 0 0 0 8px;
    display: grid;
    gap: 10px;
    justify-self: end;
    width: min(420px, 100%);
  }
  .demo-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    transition: border-color 0.25s ease, transform 0.25s ease, background 0.25s ease;
  }
  .demo-row .row-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--border);
    flex: none;
    transition: background 0.25s ease, box-shadow 0.25s ease;
  }
  .row-name {
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .row-cat {
    margin-left: auto;
    color: var(--faint);
    font-size: 0.76rem;
    font-family: var(--mono);
  }
  .row-run {
    color: var(--green);
    font-size: 0.6rem;
  }
  .demo-row.active {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
    background: linear-gradient(90deg, var(--accent-soft), transparent);
    transform: translateX(4px);
  }
  .demo-row.active .row-dot {
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  @media (max-width: 760px) {
    .demo-stage {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .demo-svg {
      display: none;
    }
    .demo-rows {
      justify-self: stretch;
      width: 100%;
    }
  }
</style>

<script>
  const stage = document.querySelector<HTMLElement>('.demo-stage')
  if (stage) {
    type A = { id: string; title: string; cat: string; runnable: boolean }
    const data: A[] = JSON.parse(stage.dataset.agents || '[]')
    const rows = Array.from(stage.querySelectorAll<HTMLElement>('.demo-row'))
    const lines = Array.from(stage.querySelectorAll<SVGPathElement>('.demo-line'))
    const svg = stage.querySelector<SVGSVGElement>('.demo-svg')
    const core = stage.querySelector<HTMLElement>('.demo-core')
    const idEl = document.getElementById('demo-id')
    const copyEl = document.getElementById('demo-copy')
    const R = rows.length
    const N = data.length
    let start = 0
    let active = 0
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches

    const paint = () => {
      rows.forEach((row, i) => {
        const a = data[(start + i) % N]
        if (!a) return
        row.querySelector('.row-name')!.textContent = a.title
        row.querySelector('.row-cat')!.textContent = a.cat
        const run = row.querySelector('.row-run')
        if (run) (run as HTMLElement).style.display = a.runnable ? '' : 'none'
        row.classList.toggle('active', i === active)
      })
      lines.forEach((ln, i) => ln.classList.toggle('active', i === active))
      const cur = data[(start + active) % N]
      if (cur && idEl) idEl.textContent = cur.id
      if (cur && copyEl) copyEl.setAttribute('data-copy', `npx agentskit add ${cur.id}`)
    }

    // Draw the connector paths in pixels so they always reach the row boxes.
    const layout = () => {
      if (!svg || !core) return
      const s = stage.getBoundingClientRect()
      if (s.width === 0) return
      svg.setAttribute('viewBox', `0 0 ${s.width} ${s.height}`)
      const c = core.getBoundingClientRect()
      const sx = c.right - s.left
      const sy = c.top + c.height / 2 - s.top
      rows.forEach((row, i) => {
        const r = row.getBoundingClientRect()
        const ex = r.left - s.left
        const ey = r.top + r.height / 2 - s.top
        const mx = sx + (ex - sx) * 0.5
        lines[i]?.setAttribute('d', `M${sx},${sy} C${mx},${sy} ${mx},${ey} ${ex},${ey}`)
      })
    }

    paint()
    layout()
    requestAnimationFrame(layout)
    window.addEventListener('resize', layout)
    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(layout)

    if (!reduce && N > 0) {
      setInterval(() => {
        active++
        if (active >= R) {
          active = 0
          start = (start + R) % N
        }
        paint()
      }, 1100)
    }
  }
</script>
