---
import { locales, getLocale, localizedPath, t, type Locale } from '../i18n/ui'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  /** Logical path WITHOUT locale prefix, e.g. "/" or "/agents/research". */
  path: string
  ogImage?: string
  type?: 'website' | 'article'
  jsonLd?: unknown
}
const { title, description, path, ogImage, type = 'website', jsonLd } = Astro.props
const locale = getLocale(Astro.currentLocale)
const tr = t(locale)
const site = 'https://registry.agentskit.io'
const canonical = site + localizedPath(path, locale)
const og = ogImage ?? `${site}/og/default.png`
const HREFLANG: Record<Locale, string> = { en: 'en', pt: 'pt-BR', es: 'es' }
const jsonLdArr = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{locales.map((l) => <link rel="alternate" hreflang={HREFLANG[l]} href={site + localizedPath(path, l)} />)}
<link rel="alternate" hreflang="x-default" href={site + localizedPath(path, 'en')} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content="AgentsKit Registry" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={og} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={HREFLANG[locale].replace('-', '_')} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@agentskit" />
<meta name="twitter:creator" content="@agentskit" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={og} />

<!-- Icons -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="generator" content={Astro.generator} />

<!-- LLM discovery -->
<link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />

{jsonLdArr.map((node) => <script type="application/ld+json" set:html={JSON.stringify(node)} />)}

<!-- No-flash theme -->
<script is:inline>
  ;(() => {
    try {
      const s = localStorage.getItem('theme')
      const t = s || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')
      document.documentElement.setAttribute('data-theme', t)
    } catch {
      document.documentElement.setAttribute('data-theme', 'dark')
    }
  })()
</script>

<!-- preload primary font -->
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.18/index.min.css"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.18/index.min.css" />
</noscript>
<meta name="robots" content="index,follow" />
<meta name="author" content="AgentsKit" />
<meta name="application-name" content="AgentsKit Registry" />
<meta property="og:image:alt" content={title} />
<meta name="twitter:image:alt" content={title} />
<meta name="msapplication-TileColor" content="#0d1117" />
<meta name="color-scheme" content="dark light" />
<meta name="format-detection" content="telephone=no" />
<meta name="locale" content={HREFLANG[locale]} />
{/* helps language-aware crawlers */}
<meta http-equiv="content-language" content={HREFLANG[locale]} />
