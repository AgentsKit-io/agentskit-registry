---
// AgentsKit mark — triangle "A" with three graph nodes. Recolored per-site via
// currentColor (registry = accent blue). Matches the sibling sites' favicon.
interface Props {
  size?: number
  class?: string
}
const { size = 28, class: cls = '' } = Astro.props
const h = Math.round((size * 64) / 72)
---
<svg
  width={size}
  height={h}
  viewBox="0 0 72 64"
  fill="none"
  class={cls}
  role="img"
  aria-label="AgentsKit"
>
  <g stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
    <line x1="16" y1="50" x2="36" y2="16"></line>
    <line x1="36" y1="16" x2="56" y2="50"></line>
    <line x1="16" y1="50" x2="56" y2="50"></line>
  </g>
  <circle cx="36" cy="16" r="7" fill="currentColor"></circle>
  <circle cx="16" cy="50" r="7" fill="currentColor"></circle>
  <circle cx="56" cy="50" r="7" fill="currentColor"></circle>
</svg>
