---
import Icon from './Icon.astro'
import CopyButton from './CopyButton.astro'
import { getLocale, t, localizedPath, categoryMeta } from '../i18n/ui'
import type { AgentSummary } from '../data/registry'
import { installCommand } from '../data/registry'

interface Props {
  agent: AgentSummary
}
const { agent } = Astro.props
const locale = getLocale(Astro.currentLocale)
const tr = t(locale)
const cat = categoryMeta(locale, agent.category)
const href = localizedPath(`/agents/${agent.id}`, locale)
---
<article class="card card-link agent-card reveal">
  <a class="ac-main" href={href}>
    <div class="ac-top">
      <span class="badge ac-cat">{cat.label}</span>
      {
        agent.runnable && (
          <span class="badge badge-green ac-run" title={tr.agent.runnableHint}>
            <span class="rdot" />
            {tr.agent.runnable}
          </span>
        )
      }
    </div>
    <div class="ac-titlerow">
      <span class="ac-bot"><Icon name="bot" size={18} /></span>
      <h3 class="ac-title">{agent.title}</h3>
    </div>
    <p class="ac-desc">{agent.description}</p>
  </a>
  <div class="ac-foot">
    <code class="ac-cmd">{installCommand(agent.id)}</code>
    <CopyButton value={installCommand(agent.id)} label={tr.copy.copy} copied={tr.copy.copied} variant="icon" />
  </div>
</article>

<style>
  .agent-card {
    display: flex;
    flex-direction: column;
    padding: 0;
  }
  .ac-main {
    padding: 20px 20px 14px;
    display: block;
    flex: 1;
  }
  .ac-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .ac-cat {
    color: var(--accent);
    background: var(--accent-soft);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border));
  }
  .ac-run .rdot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
  }
  .ac-titlerow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 7px;
  }
  .ac-bot {
    flex: none;
    width: 32px;
    height: 32px;
    border-radius: 9px;
    display: grid;
    place-items: center;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border));
  }
  .card-link:hover .ac-bot {
    color: var(--accent-2);
  }
  .ac-title {
    font-size: 1.12rem;
    margin: 0;
  }
  .ac-desc {
    color: var(--muted);
    font-size: 0.92rem;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ac-foot {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px 12px 16px;
    border-top: 1px solid var(--border-soft);
    background: var(--surface-2);
  }
  .ac-cmd {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }
  .agent-card :global(.copy-btn.cb-icon),
  .agent-card :global(.copy-btn) {
    padding: 7px;
  }
</style>
