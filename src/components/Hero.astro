---
import Icon from './Icon.astro'
import { getLocale, t, localizedPath } from '../i18n/ui'

interface Props {
  agentCount: number
  categoryCount: number
  sampleIds: string[]
}
const { agentCount, categoryCount, sampleIds } = Astro.props
const locale = getLocale(Astro.currentLocale)
const tr = t(locale)
const browse = localizedPath('/#agents', locale)
---
<section class="hero">
  <div class="aurora"></div>
  <div class="grid-bg"></div>
  <div class="container hero-inner">
    <h1 class="hero-title">
      {tr.hero.title1}<br /><span class="gradient-text">{tr.hero.title2}</span>
    </h1>
    <p class="hero-sub section-sub">{tr.hero.subtitle}</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={browse}>{tr.hero.ctaBrowse}<Icon name="arrow-right" size={17} /></a>
      <a class="btn btn-ghost" href="https://github.com/AgentsKit-io/agentskit-registry" rel="noopener">
        <Icon name="github" size={16} />{tr.hero.ctaGallery}
      </a>
    </div>

    <div class="terminal" data-ids={JSON.stringify(sampleIds)}>
      <div class="term-bar">
        <span class="tdot" style="background:#ff5f56"></span>
        <span class="tdot" style="background:#ffbd2e"></span>
        <span class="tdot" style="background:#27c93f"></span>
        <span class="term-label"><Icon name="terminal" size={13} /> install</span>
      </div>
      <div class="term-body">
        <code><span class="term-prompt">$</span> <span id="typed" class="caret"></span></code>
        <button id="term-copy" class="term-copy" type="button" data-copy={`npx agentskit add ${sampleIds[0]}`} data-label="copy" data-copied="ok" aria-label={tr.hero.copyHint}>
          <Icon name="copy" size={15} class="tc-copy" />
          <Icon name="check" size={15} class="tc-check" />
        </button>
      </div>
    </div>

    <div class="hero-stats">
      <div><b>{agentCount}</b> <span>{tr.stats.agents}</span></div>
      <div class="hs-sep"></div>
      <div><b>{categoryCount}</b> <span>{tr.stats.categories}</span></div>
      <div class="hs-sep"></div>
      <div><b>∞</b> <span>{tr.stats.ownYourCode}</span></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 92px 0 64px;
    text-align: center;
    isolation: isolate;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    margin: 0 0 18px;
    font-weight: 800;
  }
  .hero-sub {
    margin: 0 auto;
    text-align: center;
    font-size: clamp(1rem, 2vw, 1.18rem);
  }
  .hero-cta {
    display: flex;
    gap: 12px;
    margin: 28px 0 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .terminal {
    width: min(560px, 100%);
    margin: 36px auto 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    text-align: left;
    box-shadow: var(--shadow);
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-soft);
    background: var(--surface-2);
  }
  .tdot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .term-label {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--faint);
    font-size: 0.78rem;
  }
  .term-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 18px 16px;
    font-family: var(--mono);
    font-size: 0.95rem;
  }
  .term-prompt {
    color: var(--accent);
    user-select: none;
  }
  #typed {
    color: var(--text);
  }
  .term-copy {
    position: relative;
    width: 30px;
    height: 30px;
    flex: none;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .term-copy:hover {
    color: var(--text);
    border-color: var(--accent);
  }
  .term-copy :global(svg) {
    position: absolute;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .tc-check {
    opacity: 0;
    transform: scale(0.6);
    color: var(--green);
  }
  .term-copy.is-copied .tc-copy {
    opacity: 0;
  }
  .term-copy.is-copied .tc-check {
    opacity: 1;
    transform: none;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-top: 34px;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .hero-stats b {
    color: var(--text);
    font-size: 1.15rem;
    margin-right: 5px;
  }
  .hs-sep {
    width: 1px;
    height: 22px;
    background: var(--border);
  }
  @media (max-width: 520px) {
    .hero-stats {
      gap: 14px;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>

<script>
  const term = document.querySelector<HTMLElement>('.terminal')
  const typed = document.getElementById('typed')
  const copyBtn = document.getElementById('term-copy')
  if (term && typed) {
    const ids: string[] = JSON.parse(term.dataset.ids || '[]')
    const prefix = 'npx agentskit add '
    let i = 0
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches
    const setCmd = (s: string) => {
      typed.textContent = s
      copyBtn?.setAttribute('data-copy', s)
    }
    if (reduce || !ids.length) {
      setCmd(prefix + (ids[0] ?? 'research'))
    } else {
      const loop = async () => {
        const id = ids[i % ids.length]
        const full = prefix + id
        for (let c = prefix.length; c <= full.length; c++) {
          setCmd(full.slice(0, c))
          await new Promise((r) => setTimeout(r, 55))
        }
        await new Promise((r) => setTimeout(r, 1900))
        for (let c = full.length; c >= prefix.length; c--) {
          setCmd(full.slice(0, c))
          await new Promise((r) => setTimeout(r, 22))
        }
        i++
        loop()
      }
      setCmd(prefix)
      loop()
    }
  }
</script>
