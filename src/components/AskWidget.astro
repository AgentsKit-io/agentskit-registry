---
interface Props {
  endpoint?: string
  corpus: string
  title: string
  fabLabel: string
  placeholder: string
  emptyState: string
  accent: string
}

const {
  endpoint = import.meta.env.PUBLIC_ASK_ENDPOINT ?? 'https://ask.agentskit.io/v1/ask',
  corpus,
  title,
  fabLabel,
  placeholder,
  emptyState,
  accent,
} = Astro.props
---

<div
  class="ask-widget"
  data-endpoint={endpoint}
  data-corpus={corpus}
  data-title={title}
  data-empty={emptyState}
  style={`--ask-accent: ${accent}`}
>
  <button class="ask-fab" type="button">{fabLabel}</button>
  <section class="ask-panel" aria-label={title} hidden>
    <header>
      <strong>{title}</strong>
      <div>
        <button type="button" data-clear>clear</button>
        <button type="button" data-close>close</button>
      </div>
    </header>
    <div class="ask-body">
      <p class="ask-empty">{emptyState}</p>
      <div class="ask-messages"></div>
      <p class="ask-error" hidden></p>
    </div>
    <footer>
      <textarea rows="2" placeholder={placeholder}></textarea>
      <button type="button" data-send>send</button>
    </footer>
  </section>
</div>

<script is:inline>
  for (const widget of document.querySelectorAll('.ask-widget:not([data-mounted])')) {
    if (!(widget instanceof HTMLElement)) continue
    widget.dataset.mounted = 'true'
    const fab = widget.querySelector('.ask-fab')
    const panel = widget.querySelector('.ask-panel')
    const messagesEl = widget.querySelector('.ask-messages')
    const emptyEl = widget.querySelector('.ask-empty')
    const errorEl = widget.querySelector('.ask-error')
    const input = widget.querySelector('textarea')
    const sendBtn = widget.querySelector('[data-send]')
    const clearBtn = widget.querySelector('[data-clear]')
    const closeBtn = widget.querySelector('[data-close]')
    const endpoint = widget.dataset.endpoint || 'https://ask.agentskit.io/v1/ask'
    const corpus = widget.dataset.corpus || 'registry'
    const storageKey = `ak:ask-thread-v2:${corpus}`
    let messages = []
    let streaming = false
    let abortController = null

    const endpointWithCorpus = () => {
      const url = new URL(endpoint, window.location.origin)
      url.searchParams.set('corpus', corpus)
      return endpoint.startsWith('/') ? `${url.pathname}${url.search}` : url.toString()
    }

    const decode = (buffer) => {
      const lines = buffer.split('\n')
      const rest = lines.pop() || ''
      const events = []
      for (const line of lines) {
        if (!line.trim()) continue
        try {
          events.push(JSON.parse(line))
        } catch {
          /* ignore partial/unknown lines */
        }
      }
      return { events, rest }
    }

    const persist = () => {
      try {
        sessionStorage.setItem(storageKey, JSON.stringify(messages.slice(-20)))
      } catch {
        /* ignore */
      }
    }

    const render = () => {
      if (!(messagesEl instanceof HTMLElement) || !(emptyEl instanceof HTMLElement) || !(errorEl instanceof HTMLElement)) return
      messagesEl.innerHTML = ''
      emptyEl.hidden = messages.length > 0
      for (const message of messages) {
        const node = document.createElement('div')
        node.className = `ask-message ${message.role}`
        node.textContent = message.content || (message.role === 'assistant' && streaming ? 'Searching...' : '')
        messagesEl.appendChild(node)
      }
      messagesEl.scrollIntoView({ block: 'end' })
      persist()
    }

    try {
      const raw = sessionStorage.getItem(storageKey)
      if (raw) messages = JSON.parse(raw)
    } catch {
      messages = []
    }
    render()

    fab?.addEventListener('click', () => {
      if (panel instanceof HTMLElement) panel.hidden = false
      if (fab instanceof HTMLElement) fab.hidden = true
    })
    closeBtn?.addEventListener('click', () => {
      if (panel instanceof HTMLElement) panel.hidden = true
      if (fab instanceof HTMLElement) fab.hidden = false
    })
    clearBtn?.addEventListener('click', () => {
      messages = []
      render()
    })

    const send = async () => {
      if (!(input instanceof HTMLTextAreaElement) || !(sendBtn instanceof HTMLButtonElement)) return
      const text = input.value.trim()
      if (!text || streaming) return
      const next = [...messages, { role: 'user', content: text }]
      messages = [...next, { role: 'assistant', content: '' }]
      input.value = ''
      streaming = true
      sendBtn.textContent = 'stop'
      abortController = new AbortController()
      if (errorEl instanceof HTMLElement) {
        errorEl.hidden = true
        errorEl.textContent = ''
      }
      render()

      try {
        const res = await fetch(endpointWithCorpus(), {
          method: 'POST',
          signal: abortController.signal,
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ messages: next }),
        })
        if (!res.ok || !res.body) throw new Error(`${res.status} ${res.statusText}`)
        const reader = res.body.getReader()
        const decoder = new TextDecoder()
        let buffer = ''
        while (true) {
          const { value, done } = await reader.read()
          if (done) break
          buffer += decoder.decode(value, { stream: true })
          const decoded = decode(buffer)
          buffer = decoded.rest
          for (const event of decoded.events) {
            if (event.type === 'error') throw new Error(event.message || 'The assistant could not answer.')
            if (event.type === 'text' && event.delta) {
              const last = messages[messages.length - 1]
              if (last?.role === 'assistant') last.content += event.delta
              render()
            }
          }
        }
      } catch (err) {
        if (!abortController?.signal.aborted && errorEl instanceof HTMLElement) {
          errorEl.textContent = err instanceof Error ? err.message : String(err)
          errorEl.hidden = false
        }
      } finally {
        streaming = false
        sendBtn.textContent = 'send'
        abortController = null
        render()
      }
    }

    sendBtn?.addEventListener('click', () => {
      if (streaming) abortController?.abort()
      else void send()
    })
    input?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault()
        void send()
      }
    })
  }
</script>

<style>
  .ask-fab,
  .ask-panel {
    position: fixed;
    right: 18px;
    z-index: 80;
    font-family: var(--mono);
  }
  .ask-fab {
    bottom: 18px;
    border: 1px solid color-mix(in srgb, var(--ask-accent) 48%, var(--border));
    border-radius: 999px;
    background: var(--surface);
    color: var(--text);
    padding: 10px 14px;
    box-shadow: var(--shadow);
  }
  .ask-panel {
    bottom: 18px;
    display: flex;
    width: min(430px, calc(100vw - 24px));
    height: min(620px, calc(100vh - 36px));
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    box-shadow: var(--shadow);
  }
  .ask-panel[hidden],
  .ask-fab[hidden] {
    display: none;
  }
  .ask-panel header,
  .ask-panel footer {
    padding: 10px;
    border-color: var(--border);
  }
  .ask-panel header {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
  }
  .ask-panel button {
    color: var(--ask-accent);
    background: transparent;
    border: 0;
    font: inherit;
    font-size: 11px;
    text-transform: uppercase;
  }
  .ask-body {
    flex: 1;
    overflow: auto;
    padding: 12px;
  }
  .ask-empty,
  .ask-error {
    color: var(--muted);
    font-size: 13px;
  }
  .ask-error {
    color: #ff7b72;
  }
  .ask-message {
    margin: 0 0 10px;
    white-space: pre-wrap;
    font-size: 13px;
    line-height: 1.55;
  }
  .ask-message.user {
    margin-left: auto;
    max-width: 82%;
    border-radius: 10px;
    background: var(--accent-soft);
    padding: 8px 10px;
  }
  .ask-panel footer {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    border-top: 1px solid var(--border);
  }
  .ask-panel textarea {
    resize: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--text);
    padding: 8px;
    font: inherit;
    font-size: 12px;
  }
</style>
